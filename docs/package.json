{
  "name": "@openuidev/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:prompts": "pnpm --filter @openuidev/cli build && pnpm exec openui generate lib/chat-library.ts --out generated/chat-system-prompt.txt && pnpm exec openui generate lib/playground-library.ts --out generated/playground-system-prompt.txt && pnpm exec openui generate lib/playground-library.ts --json-schema --out generated/playground-component-spec.json",
    "build": "next build",
    "dev": "pnpm generate:prompts && next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "format:fix": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@openuidev/cli": "workspace:*",
    "@openuidev/lang-core": "workspace:^",
    "@openuidev/react-lang": "workspace:^",
    "@openuidev/react-headless": "workspace:^",
    "@openuidev/react-ui": "workspace:^",
    "openai": "^6.22.0",
    "@takumi-rs/image-response": "^0.68.17",
    "fumadocs-core": "16.6.5",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-ui": "16.6.5",
    "gpt-tokenizer": "^3.4.0",
    "lucide-react": "^0.570.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "posthog-js": "^1.358.1",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.1",
    "octokit": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}
